# ShopNow - .gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Production builds
build/
dist/
.next/
out/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE & Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Docker
.dockerignore

# Kubernetes secrets (should never be committed)
**/secrets/
**/secret*.yaml
kubernetes/k8s-manifests/**/secrets-*.yaml

# Temporary files
*.tmp
*.temp
.cache/
.temp/

# Test coverage
coverage/
*.lcov
.nyc_output/

# Misc
.sass-cache/
connect.lock
typings/

# AWS
.aws/

# Jenkins
.jenkins/

# Helm packages
*.tgz

# Backup files
*.bak
*.backup
*~

# Local configuration overrides
config.local.js
config.local.json

# Build artifacts
*.tar.gz
*.zip
