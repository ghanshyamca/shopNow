#!/usr/bin/env groovy

/*
 * ShopNow Backend - CD Pipeline
 * Purpose: Deploy backend to Kubernetes using HELM
 * Trigger: Manual or after CI pipeline success
 */

pipeline {
    agent any
    
    environment {
        AWS_REGION = "${env.AWS_DEFAULT_REGION ?: 'ap-south-1'}"
        CLUSTER_NAME = "${env.EKS_CLUSTER_NAME ?: 'shopnow-eks-cluster'}"
        NAMESPACE = 'shopnow-demo'
        CHART_PATH = './kubernetes/helm/charts/backend'
        RELEASE_NAME = 'backend'
        IMAGE_TAG = "${params.IMAGE_TAG ?: 'latest'}"
    }
    
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag to deploy')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Run helm in dry-run mode')
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo '=== Checking out source code ==='
                checkout scm
            }
        }
        
        stage('Setup kubectl') {
            steps {
                echo '=== Configuring kubectl for EKS ==='
                script {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        powershell """
                            \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                            \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                            \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                            
                            aws eks update-kubeconfig `
                                --region ${AWS_REGION} `
                                --name ${CLUSTER_NAME}
                        """
                    }
                }
            }
        }
        
        stage('Verify Cluster Access') {
            steps {
                echo '=== Verifying cluster connectivity ==='
                script {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        powershell """
                            \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                            \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                            \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                            
                            kubectl cluster-info
                            kubectl get nodes
                        """
                    }
                }
            }
        }
        
        stage('Check Namespace') {
            steps {
                echo '=== Checking if namespace exists ==='
                script {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        powershell """
                            \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                            \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                            \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                            
                            \$namespaceExists = kubectl get namespace ${NAMESPACE} 2>\$null
                            if (-not \$namespaceExists) {
                                Write-Host "Namespace ${NAMESPACE} not found. Creating..."
                                kubectl create namespace ${NAMESPACE}
                            } else {
                                Write-Host "Namespace ${NAMESPACE} already exists"
                            }
                        """
                    }
                }
            }
        }
        
        stage('HELM Lint') {
            steps {
                echo '=== Linting HELM chart ==='
                script {
                    powershell "helm lint ${CHART_PATH}"
                }
            }
        }
        
        stage('Deploy with HELM') {
            steps {
                echo '=== Deploying Backend with HELM ==='
                script {
                    def dryRunFlag = params.DRY_RUN ? '--dry-run' : ''
                    
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        powershell """
                            \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                            \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                            \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                            
                            helm upgrade --install ${RELEASE_NAME} ${CHART_PATH} `
                                --namespace ${NAMESPACE} `
                                --set image.tag=${IMAGE_TAG} `
                                --create-namespace `
                                --wait `
                                --timeout 5m `
                                ${dryRunFlag}
                        """
                    }
                }
            }
        }
        
        stage('Verify Deployment') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                echo '=== Verifying deployment status ==='
                script {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        powershell """
                            \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                            \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                            \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                            
                            echo "Checking pods..."
                            kubectl get pods -n ${NAMESPACE} -l app.kubernetes.io/name=backend
                            
                            echo "\nChecking deployment..."
                            kubectl rollout status deployment/${RELEASE_NAME} -n ${NAMESPACE} --timeout=5m
                            
                            echo "\nChecking service..."
                            kubectl get svc -n ${NAMESPACE} -l app.kubernetes.io/name=backend
                        """
                    }
                }
            }
        }
        
        stage('Show Resources') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                echo '=== Displaying deployed resources ==='
                script {
                    withCredentials([[
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-credentials',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]]) {
                        powershell """
                            \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                            \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                            \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                            
                            echo "=== HELM Release Info ==="
                            helm list -n ${NAMESPACE}
                            
                            echo "\n=== Backend Deployment ==="
                            kubectl describe deployment/${RELEASE_NAME} -n ${NAMESPACE}
                            
                            echo "\n=== Backend Pods ==="
                            kubectl get pods -n ${NAMESPACE} -l app.kubernetes.io/name=backend -o wide
                        """
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo '=== Backend CD Pipeline Completed Successfully ==='
            echo "Backend deployed with image tag: ${IMAGE_TAG}"
        }
        failure {
            echo '=== Backend CD Pipeline Failed ==='
            script {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    powershell """
                        \$env:AWS_ACCESS_KEY_ID = \$env:AWS_ACCESS_KEY_ID
                        \$env:AWS_SECRET_ACCESS_KEY = \$env:AWS_SECRET_ACCESS_KEY
                        \$env:AWS_DEFAULT_REGION = '${AWS_REGION}'
                        
                        Write-Host "Recent events in namespace:"
                        kubectl get events -n ${NAMESPACE} --sort-by='.lastTimestamp' | Select-Object -Last 20
                    """
                }
            }
        }
        always {
            echo '=== Pipeline Execution Finished ==='
        }
    }
}

